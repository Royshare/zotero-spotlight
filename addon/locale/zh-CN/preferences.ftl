pref-shortcut-section = 快捷键
pref-shortcut-primary = Cmd+P (MacOS) or Ctrl+P (Windows/Linux)
pref-shortcut-fallback = Cmd+Shift+P (MacOS) or Ctrl+Shift+P (Windows/Linux)
pref-results-section = 结果限制
pref-results-limit = 结果数量上限

pref-window-section = 窗口尺寸
pref-window-height = 高度 (px)
pref-window-width = 宽度 (px)
pref-search-section = 搜索
pref-search-annotations = 搜索批注
pref-restore-search = 重新打开 Spotlight 时恢复上一次搜索
pref-reset-defaults = 恢复默认设置
pref-ai-section = AI 命令
pref-ai-enabled = 启用 AI 命令（>ask、>summarize、>draft note）
pref-ai-provider = 服务商
pref-ai-provider-openai = OpenAI（或兼容服务）
pref-ai-provider-ollama = Ollama（本地）
pref-ai-model = 模型
pref-ai-api-key = API 密钥
pref-ai-base-url = Base URL
pref-ai-base-url-placeholder = 留空使用服务商默认值
